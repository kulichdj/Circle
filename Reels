<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Circle lf — Reels Demo Simulator</title>
    <style>
        body {
            background: #050508;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            overflow: hidden;
        }
        /* Кнопка управления режиссером */
        .director-panel {
            position: absolute; top: 20px; z-index: 9999;
            background: rgba(255,255,255,0.07); backdrop-filter: blur(10px);
            padding: 10px 20px; border-radius: 30px; border: 1px solid rgba(255,255,255,0.1);
        }
        .start-btn {
            background: #00ffd2; color: #000; border: none; padding: 10px 20px;
            border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 0.9rem;
            box-shadow: 0 0 20px rgba(0,255,210,0.4);
        }
        /* Стилизованный под Reels макет смартфона */
        .phone-container {
            width: 390px; height: 844px; /* Пропорции iPhone 13/14 Pro */
            background: #0b0c10; border-radius: 45px;
            box-shadow: 0 25px 100px rgba(0,0,0,0.9), 0 0 0 12px #1c1c1e;
            overflow: hidden; position: relative;
            display: flex; flex-direction: column;
            transform: scale(0.9); transition: all 0.5s ease;
        }
        /* Виртуальный интерфейс Circle lf внутри */
        .app-view {
            width: 100%; height: 100%; padding: 40px 20px; box-sizing: border-box;
            background: radial-gradient(circle at 15% 15%, rgba(120, 119, 198, 0.2) 0%, transparent 50%),
                        radial-gradient(circle at 85% 85%, rgba(244, 114, 182, 0.1) 0%, transparent 50%);
            color: #fff; display: flex; flex-direction: column; gap: 20px;
            overflow-y: auto; scroll-behavior: smooth;
        }
        .app-view::-webkit-scrollbar { width: 0; } /* Прячем скроллбар для красоты */

        /* Элементы интерфейса */
        .glass-card {
            background: linear-gradient(135deg, rgba(35, 37, 49, 0.45) 0%, rgba(15, 16, 22, 0.65) 100%);
            backdrop-filter: blur(30px); border-radius: 24px; padding: 20px;
            border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; gap: 20px;
        }
        .circle-progress {
            width: 90px; height: 90px; border-radius: 50%;
            background: conic-gradient(#ffffff var(--p, 0%), rgba(255,255,255,0.05) 0%);
            display: flex; align-items: center; justify-content: center;
            position: relative; transition: --p 0.8s;
        }
        .circle-progress::after {
            content: '4'; position: absolute; width: 80px; height: 80px;
            background: #0b0c10; border-radius: 50%; display: flex;
            align-items: center; justify-content: center; font-size: 2rem; font-weight: 100;
        }
        .spheres-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .sphere-card {
            background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
            border-radius: 20px; padding: 15px; display: flex; flex-direction: column; align-items: center; text-align: center;
        }
        .mini-circle {
            width: 50px; height: 50px; border-radius: 50%;
            background: conic-gradient(#ffffff var(--sp, 20%), rgba(255,255,255,0.05) 0%);
            display: flex; align-items: center; justify-content: center; margin-bottom: 8px;
        }
        .mini-circle::after {
            content: '2'; position: absolute; width: 44px; height: 44px;
            background: #14151b; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;
        }
        .quest-item {
            background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px; padding: 14px; display: flex; justify-content: space-between; align-items: center;
            transition: all 0.5s ease;
        }
        .check-btn {
            width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.2);
            background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #fff;
        }
        /* Всплывающее окно Левелапа */
        .lvl-popup {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.7);
            background: rgba(255,255,255,0.95); color: #000; padding: 25px; border-radius: 24px;
            text-align: center; width: 260px; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            opacity: 0; pointer-events: none; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 100;
        }
        .lvl-popup.active { opacity: 1; transform: translate(-50%, -50%) scale(1); }
        
        /* Эффект клика курсора для видео */
        .virtual-cursor {
            position: absolute; width: 20px; height: 20px; background: rgba(0,255,210,0.6);
            border-radius: 50%; pointer-events: none; z-index: 9999; opacity: 0;
            transform: translate(-50%, -50%); transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body>

    <div class="director-panel">
        <button class="start-btn" onclick="startReelsDemo()">🎬 ЗАПУСТИТЬ ЗАПИСЬ ДЛЯ REELS</button>
    </div>

    <!-- Виртуальный курсор мыши для симуляции тапов -->
    <div class="virtual-cursor" id="cursor"></div>

    <div class="phone-container" id="phone">
        <div class="app-view" id="appScroll">
            
            <!-- ЯДРО АККАУНТА -->
            <div class="glass-card">
                <div class="circle-progress" id="mainCircle" style="--p: 35%;"></div>
                <div>
                    <div style="font-size: 0.65rem; color: #a1a1aa; letter-spacing: 1px; text-transform: uppercase;">Ранг аккаунта</div>
                    <div style="font-size: 1.3rem; font-weight: 300; margin-top: 2px;">Новичок фокуса</div>
                    <div style="font-size: 0.75rem; color: #a1a1aa; margin-top: 4px;" id="mainXpText">35 / 100 XP</div>
                </div>
            </div>

            <!-- СФЕРЫ -->
            <div class="spheres-grid">
                <div class="sphere-card">
                    <div class="mini-circle" id="sphere0" style="--sp: 15%;"></div>
                    <div style="font-size: 0.8rem;">Работа</div>
                </div>
                <div class="sphere-card">
                    <div class="mini-circle" style="--sp: 45%;"></div>
                    <div style="font-size: 0.8rem;">Хобби</div>
                </div>
                <div class="sphere-card">
                    <div class="mini-circle" style="--sp: 70%;"></div>
                    <div style="font-size: 0.8rem;">Отдых</div>
                </div>
                <div class="sphere-card">
                    <div class="mini-circle" style="--sp: 10%;"></div>
                    <div style="font-size: 0.8rem;">Спорт</div>
                </div>
            </div>

            <!-- ЗАДАЧИ -->
            <div style="font-size: 0.8rem; text-transform: uppercase; color: #a1a1aa; letter-spacing: 1px; margin-top: 10px;">Цели на сегодня</div>
            
            <div class="quest-item" id="q1">
                <div>
                    <div style="font-size: 0.95rem;">Провести созвон по проекту</div>
                    <span style="font-size: 0.65rem; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 6px; color:#a1a1aa;">Работа</span>
                </div>
                <button class="check-btn" id="btn1">✓</button>
            </div>

            <div class="quest-item" id="q2">
                <div>
                    <div style="font-size: 0.95rem;">Силовая тренировка (30 мин)</div>
                    <span style="font-size: 0.65rem; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 6px; color:#a1a1aa;">Спорт</span>
                </div>
                <button class="check-btn">✓</button>
            </div>

            <div class="quest-item" id="q3">
                <div>
                    <div style="font-size: 0.95rem;">Почитать книгу по бизнесу</div>
                    <span style="font-size: 0.65rem; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 6px; color:#a1a1aa;">Хобби</span>
                </div>
                <button class="check-btn">✓</button>
            </div>

        </div>

        <!-- Попап уровня -->
        <div class="lvl-popup" id="lvlPopup">
            <h3 style="margin: 0 0 10px 0; font-size: 1.3rem;">УРОВЕНЬ АПНУТ! 🚀</h3>
            <p style="margin: 0 0 20px 0; font-size: 0.9rem; color: #555;">Вы перешли на 5 уровень ранга аккаунта.</p>
            <button style="background: #000; color: #fff; border: none; padding: 10px 20px; border-radius: 12px; width: 100%; font-weight: bold;" id="closePopupBtn">Продолжить</button>
        </div>
    </div>

    <script>
        function moveCursor(targetEl, callback) {
            const cursor = document.getElementById('cursor');
            const rect = targetEl.getBoundingClientRect();
            cursor.style.opacity = '1';
            cursor.style.left = (rect.left + rect.width/2) + 'px';
            cursor.style.top = (rect.top + rect.height/2) + 'px';
            setTimeout(callback, 800);
        }

        function startReelsDemo() {
            const phone = document.getElementById('phone');
            const scrollContainer = document.getElementById('appScroll');
            const mainCircle = document.getElementById('mainCircle');
            const mainXpText = document.getElementById('mainXpText');
            const sphere0 = document.getElementById('sphere0');
            const q1 = document.getElementById('q1');
            const btn1 = document.getElementById('btn1');
            const lvlPopup = document.getElementById('lvlPopup');
            const closePopupBtn = document.getElementById('closePopupBtn');
            const cursor = document.getElementById('cursor');

            // Сцена 1: Плавное появление и легкий наклон смартфона для кино-эффекта
            phone.style.transform = 'scale(1) rotate(-1deg)';
            
            // Сцена 2: Имитация скролла вниз, чтобы показать масштаб интерфейса
            setTimeout(() => {
                scrollContainer.scrollTop = 120;
            }, 1500);

            // Сцена 3: Возвращаем скролл к задачам
            setTimeout(() => {
                scrollContainer.scrollTop = 0;
            }, 3000);

            // Сцена 4: Виртуальный курсор двигается к кнопке выполнения задачи "Работа"
            setTimeout(() => {
                moveCursor(btn1, () => {
                    // Эффект клика
                    cursor.style.transform = 'translate(-50%, -50%) scale(0.6)';
                    btn1.style.background = '#00ffd2';
                    btn1.style.color = '#000';
                    
                    // Анимация выполнения таска (растворение)
                    setTimeout(() => {
                        q1.style.opacity = '0.3';
                        q1.style.transform = 'translateX(-10px)';
                        
                        // Заполнение сфер и главного кольца опыта (XP)
                        mainCircle.style.setProperty('--p', '100%');
                        mainXpText.innerText = "100 / 100 XP";
                        sphere0.style.setProperty('--sp', '85%');
                        cursor.style.transform = 'translate(-50%, -50%) scale(1)';
                    }, 300);
                });
            }, 4000);

            // Сцена 5: Эффектный левелап на весь экран!
            setTimeout(() => {
                cursor.style.opacity = '0';
                lvlPopup.classList.add('active');
            }, 5500);

            // Сцена 6: Закрытие левелапа и финальный красивый ракурс
            setTimeout(() => {
                moveCursor(closePopupBtn, () => {
                    lvlPopup.classList.remove('active');
                    phone.style.transform = 'scale(1.05) rotate(0deg)';
                    mainCircle.style.setProperty('--p', '15%');
                    mainXpText.innerText = "15 / 135 XP";
                    document.getElementById('mainCircle').style.setProperty('--p', '15%');
                    cursor.style.opacity = '0';
                });
            }, 7500);
        }
    </script>
</body>
</html>
